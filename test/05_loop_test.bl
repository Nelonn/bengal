#!/usr/bin/env bengal

// Stress test for loops and control flow
// Tests for, while, break, continue, and nested loops

import std.test
import std.io

// ============== For Loop Basic Tests ==============

test("For loop basic iteration", () {
    let sum = 0
    for (i in 1..5) {
        sum = sum + i
    }
    assertEquals(10, sum)  // 1+2+3+4 = 10
})

test("For loop from zero", () {
    let sum = 0
    for (i in 0..4) {
        sum = sum + i
    }
    assertEquals(6, sum)  // 0+1+2+3 = 6
})

test("For loop single iteration", () {
    let count = 0
    for (i in 1..2) {
        count = count + 1
    }
    assertEquals(1, count)
})

test("For loop with array length", () {
    let arr = [10, 20, 30, 40, 50]
    let sum = 0
    for (i in 0..arr.length()) {
        sum = sum + arr[i]
    }
    assertEquals(150, sum)
})

// ============== For Loop Edge Cases ==============

test("For loop empty range", () {
    let count = 0
    for (i in 5..5) {
        count = count + 1
    }
    assertEquals(0, count)  // Empty range, no iterations
})

test("For loop reverse range", () {
    let count = 0
    for (i in 10..5) {
        count = count + 1
    }
    // Based on example, this should iterate
    assertTrue(count >= 0)
})

test("For loop large range", () {
    let sum = 0
    for (i in 1..11) {
        sum = sum + i
    }
    assertEquals(55, sum)  // 1+2+...+10 = 55
})

// ============== While Loop Basic Tests ==============

test("While loop basic", () {
    let count = 0
    while (count < 5) {
        count = count + 1
    }
    assertEquals(5, count)
})

test("While loop countdown", () {
    let count = 5
    while (count > 0) {
        count = count - 1
    }
    assertEquals(0, count)
})

test("While loop with accumulator", () {
    let sum = 0
    let i = 1
    while (i <= 5) {
        sum = sum + i
        i = i + 1
    }
    assertEquals(15, sum)  // 1+2+3+4+5 = 15
})

// ============== While Loop Edge Cases ==============

test("While loop false condition", () {
    let count = 0
    while (false) {
        count = count + 1
    }
    assertEquals(0, count)
})

test("While loop true from start", () {
    let count = 0
    while (count < 3) {
        count = count + 1
    }
    assertEquals(3, count)
})

// ============== Break Statement ==============

test("Break in for loop", () {
    let sum = 0
    for (i in 1..10) {
        if (i == 5) {
            break
        }
        sum = sum + i
    }
    assertEquals(10, sum)  // 1+2+3+4 = 10
})

test("Break in while loop", () {
    let count = 0
    while (true) {
        if (count >= 5) {
            break
        }
        count = count + 1
    }
    assertEquals(5, count)
})

test("Break with condition", () {
    let sum = 0
    for (i in 1..20) {
        sum = sum + i
        if (sum >= 15) {
            break
        }
    }
    assertTrue(sum >= 15)
})

test("Break nested loop inner", () {
    let count = 0
    for (i in 1..5) {
        for (j in 1..10) {
            count = count + 1
            if (j == 3) {
                break
            }
        }
    }
    assertEquals(15, count)  // 5 iterations * 3 breaks = 15
})

// ============== Continue Statement ==============

test("Continue in for loop", () {
    let sum = 0
    for (i in 1..6) {
        if (i == 3) {
            continue
        }
        sum = sum + i
    }
    assertEquals(12, sum)  // 1+2+4+5 = 12 (skipped 3)
})

test("Continue in while loop", () {
    let sum = 0
    let i = 0
    while (i < 5) {
        i = i + 1
        if (i == 3) {
            continue
        }
        sum = sum + i
    }
    assertEquals(12, sum)  // 1+2+4+5 = 12 (skipped 3)
})

test("Continue skip even numbers", () {
    let sum = 0
    for (i in 1..10) {
        if (i % 2 == 0) {
            continue
        }
        sum = sum + i
    }
    assertEquals(25, sum)  // 1+3+5+7+9 = 25
})

test("Continue skip odd numbers", () {
    let sum = 0
    for (i in 1..10) {
        if (i % 2 != 0) {
            continue
        }
        sum = sum + i
    }
    assertEquals(30, sum)  // 2+4+6+8 = 20... wait, 2+4+6+8 = 20
})

// ============== Nested Loops ==============

test("Nested for loops", () {
    let count = 0
    for (i in 1..4) {
        for (j in 1..3) {
            count = count + 1
        }
    }
    assertEquals(12, count)  // 3 * 4 = 12
})

test("Nested for loops with multiplication", () {
    let sum = 0
    for (i in 1..4) {
        for (j in 1..3) {
            sum = sum + (i * j)
        }
    }
    // i=1: 1+2+3=6, i=2: 2+4+6=12, i=3: 3+6+9=18, i=4: 4+8+12=24
    assertEquals(60, sum)
})

test("Nested while loops", () {
    let count = 0
    let i = 0
    while (i < 3) {
        let j = 0
        while (j < 3) {
            count = count + 1
            j = j + 1
        }
        i = i + 1
    }
    assertEquals(9, count)  // 3 * 3 = 9
})

test("Nested loop with break and continue", () {
    let count = 0
    for (i in 1..5) {
        for (j in 1..5) {
            if (j == 2) {
                continue
            }
            if (i == 3) {
                break
            }
            count = count + 1
        }
    }
    // Complex pattern - just verify it runs
    assertTrue(count > 0)
})

// ============== Loop with Arrays ==============

test("For loop array modification", () {
    let arr = [0, 0, 0, 0, 0]
    for (i in 0..arr.length()) {
        arr[i] = i * 10
    }
    assertEquals(0, arr[0])
    assertEquals(10, arr[1])
    assertEquals(20, arr[2])
    assertEquals(30, arr[3])
    assertEquals(40, arr[4])
})

test("While loop array processing", () {
    let arr = [1, 2, 3, 4, 5]
    let sum = 0
    let i = 0
    while (i < arr.length()) {
        sum = sum + arr[i]
        i = i + 1
    }
    assertEquals(15, sum)
})

test("For loop array search with break", () {
    let arr = [5, 10, 15, 20, 25]
    let target = 15
    let found = false
    for (i in 0..arr.length()) {
        if (arr[i] == target) {
            found = true
            break
        }
    }
    assertTrue(found)
})

// ============== Loop Stress Tests ==============

test("Stress: Large for loop", () {
    let sum = 0
    for (i in 1..101) {
        sum = sum + i
    }
    assertEquals(5050, sum)  // Sum of 1 to 100
})

test("Stress: While loop many iterations", () {
    let count = 0
    while (count < 100) {
        count = count + 1
    }
    assertEquals(100, count)
})

test("Stress: Nested loops multiplication table", () {
    let sum = 0
    for (i in 1..10) {
        for (j in 1..10) {
            sum = sum + (i * j)
        }
    }
    assertEquals(3025, sum)  // Sum of 1..10 squared
})

test("Stress: Loop with multiple conditions", () {
    let count = 0
    let i = 0
    while (i < 50 && count < 25) {
        if (i % 2 == 0) {
            count = count + 1
        }
        i = i + 1
    }
    assertEquals(25, count)
})

test("Stress: Triple nested loop", () {
    let count = 0
    for (i in 1..4) {
        for (j in 1..3) {
            for (k in 1..2) {
                count = count + 1
            }
        }
    }
    assertEquals(24, count)  // 4 * 3 * 2 = 24
})

// ============== Loop with Conditionals ==============

test("For loop with if-else", () {
    let evenCount = 0
    let oddCount = 0
    for (i in 1..11) {
        if (i % 2 == 0) {
            evenCount = evenCount + 1
        } else {
            oddCount = oddCount + 1
        }
    }
    assertEquals(5, evenCount)
    assertEquals(5, oddCount)
})

test("While loop with complex condition", () {
    let sum = 0
    let i = 1
    while (i <= 10) {
        if (i > 5 && i < 10) {
            sum = sum + i * 2
        } else {
            sum = sum + i
        }
        i = i + 1
    }
    // 1+2+3+4+5 + (6*2)+(7*2)+(8*2)+(9*2) + 10 = 15+60+10 = 85
    assertEquals(85, sum)
})

// ============== Loop Variable Scope ==============

test("Loop variable after loop", () {
    let i = 0
    for (i in 1..6) {
        // Just iterate
    }
    // i should be accessible after loop
    assertTrue(i >= 5)
})

// ============== Print Summary ==============

println("")
test.summary()

// ============== Exit Status ==============

let allPassed = test.runAll()
if (allPassed) {
    println("All loop tests passed!")
}
if (!allPassed) {
    println("Some loop tests failed!")
    println("Failed: " + str(test.failedCount()) + " / " + str(test.totalCount()))
}
