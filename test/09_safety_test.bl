import std.test
import std.io

test("Division by zero throws", () {
    assertThrows(() {
        let x = 10 / 0
    })
    assertThrows(() {
        let x = 10 % 0
    })
})

test("Integer overflow addition throws", () {
    assertThrows(() {
        let max_int = 9223372036854775807
        let x = max_int + 1
    })
})

test("Integer overflow subtraction throws", () {
    assertThrows(() {
        let max_int = 9223372036854775807
        let min_int = (0 - max_int) - 1
        let x = min_int - 1
    })
})

test("Integer overflow multiplication throws", () {
    assertThrows(() {
        let max_int = 9223372036854775807
        let x = max_int * 2
    })
})

test("Increment overflow throws", () {
    assertThrows(() {
        let x = 9223372036854775807
        x++
    })
})

test("Decrement overflow throws", () {
    assertThrows(() {
        let max_int = 9223372036854775807
        let min_int = (0 - max_int) - 1
        let x = min_int
        x--
    })
})
