import std.io
import std.math

println("=== Math Constants ===")
println("PI: " + 3.14159265358)
println("E: " + 2.718281828459045)
println("TAU: " + 6.283185307179586)

println("\n=== Trigonometric Functions ===")
println("sin(0): " + sin(0.0))
println("sin(PI/2): " + sin(3.14159265358 / 2.0))
println("cos(0): " + cos(0.0))
println("cos(PI): " + cos(3.14159265358))
println("tan(0): " + tan(0.0))
println("tan(PI/4): " + tan(3.14159265358 / 4.0))
println("asin(1): " + asin(1.0))
println("acos(1): " + acos(1.0))
println("atan(1): " + atan(1.0))
println("atan2(1, 1): " + atan2(1.0, 1.0))

println("\n=== Hyperbolic Functions ===")
println("sinh(0): " + sinh(0.0))
println("cosh(0): " + cosh(0.0))
println("tanh(0): " + tanh(0.0))

println("\n=== Rounding Functions ===")
println("floor(3.7): " + floor(3.7))
println("ceil(3.2): " + ceil(3.2))
println("round(3.5): " + round(3.5))
println("trunc(3.9): " + trunc(3.9))
println("fract(3.7): " + fract(3.7))

println("\n=== Comparison Functions ===")
println("min(5.0, 3.0): " + min(5.0, 3.0))
println("max(5.0, 3.0): " + max(5.0, 3.0))
println("clamp(10.0, 0.0, 5.0): " + clamp(10.0, 0.0, 5.0))
println("abs(-5.5): " + abs(0.0 - 5.5))
println("sign(-5.5): " + sign(0.0 - 5.5))
println("sign(5.5): " + sign(5.5))
println("sign(0): " + sign(0.0))

println("\n=== Power and Root Functions ===")
println("sqrt(16): " + sqrt(16.0))
println("cbrt(27): " + cbrt(27.0))
println("pow(2, 10): " + pow(2.0, 10.0))
println("exp(1): " + exp(1.0))
println("ln(E): " + ln(2.718281828459045))
println("log10(100): " + log10(100.0))
println("log2(8): " + log2(8.0))
println("log(2, 8): " + log(2.0, 8.0))

println("\n=== Utility Functions ===")
println("hypot(3, 4): " + hypot(3.0, 4.0))
println("lerp(0, 10, 0.5): " + lerp(0.0, 10.0, 0.5))
println("step(5, 3): " + step(5.0, 3.0))
println("step(5, 7): " + step(5.0, 7.0))
println("smoothstep(0, 10, 5): " + smoothstep(0.0, 10.0, 5.0))

println("\n=== Angle Conversion ===")
println("toRadians(180): " + toRadians(180.0))
println("toDegrees(PI): " + toDegrees(3.14159265358))

println("\n=== All math tests passed! ===")
