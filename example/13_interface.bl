import std.io

interface Printable {
  fn print(text: str)
  fn log(text: str) {

  }
}

interface Drawable : Printable {
  fn draw(text: str)
}

class Circle : Drawable {
  constructor() {}

  fn print(text: str) {
    println(text)
  }
  fn draw(text: str) {
  }
}

let circle: Printable = Circle()
circle.print("test")
