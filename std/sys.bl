module std.sys

native fn exit(code: int)
native fn env(key: str): str?
native fn setPwd(dir: str)

native fn getArgs(): str[]

native class Process {
  fn start(cmd: str, args: str[], capture_stdout: bool, capture_stderr: bool, working_dir: str?)

  fn wait()

  fn exitCode(): int?

  fn getStdin(): OutputStream

  fn getStdout(): InputStream

  fn getStderr(): InputStream
}
